/// @description Configure the short floating damage animation.

self.text = "-1"
self.text_color = c_white
self.outline_color = make_color_rgb(8, 16, 20)
self.current_alpha = 1

self.age = 0
self.life_time = 32
self.fade_start = 10
self.x = round(self.x)
self.start_y = round(self.y)
self.y = self.start_y
self.rise_distance = 12
